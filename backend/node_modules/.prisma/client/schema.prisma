generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specialty {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[] @relation("DoctorSpecialty")
}

model User {
  id       Int    @id @default(autoincrement())
  rut      String @unique
  name     String
  email    String @unique
  password String
  role     String @default("PATIENT") // Roles: PATIENT, DOCTOR, ADMIN

  specialtyId Int?
  specialty   Specialty? @relation("DoctorSpecialty", fields: [specialtyId], references: [id])

  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          Int      @id @default(autoincrement())
  patientId   Int
  doctorId    Int
  date        DateTime
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  meetingLink String?

  patient User @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  User @relation("DoctorAppointments", fields: [doctorId], references: [id])

  clinicalRecord ClinicalRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClinicalRecord {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  // Constantes Vitales
  weight        Float? // kg
  height        Float? // cm
  bloodPressure String? // ej. "120/80"
  temperature   Float? // °C
  heartRate     Int? // lpm
  oxygenSat     Float? // %SpO2

  // Historial
  allergies    String?
  symptoms     String
  diagnosis    String
  prescription String? // Medicamentos, dosis y duración
  observations String? // Notas privadas del médico

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
