generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specialty {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[] @relation("DoctorSpecialty")
}

model User {
  id       Int    @id @default(autoincrement())
  rut      String @unique
  name     String
  email    String @unique
  password String
  role     String @default("PATIENT") // Roles: PATIENT, DOCTOR, ADMIN

  specialtyId Int?
  specialty   Specialty? @relation("DoctorSpecialty", fields: [specialtyId], references: [id])

  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          Int      @id @default(autoincrement())
  patientId   Int
  doctorId    Int
  date        DateTime
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  meetingLink String? // Link de la videollamada

  patient User @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  User @relation("DoctorAppointments", fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
